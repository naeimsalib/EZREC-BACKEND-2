# EZREC Backend Environment Configuration
# Copy this file to /opt/ezrec-backend/.env and fill in your values

# =============================================================================
# REQUIRED: Supabase Configuration
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# =============================================================================
# REQUIRED: User and Camera Configuration
# =============================================================================
USER_ID=your_user_id_here
CAMERA_ID=your_camera_id_here

# =============================================================================
# REQUIRED: AWS S3 Configuration
# =============================================================================
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1
AWS_S3_BUCKET=ezrec-videos
AWS_USER_MEDIA_BUCKET=ezrec-user-media

# =============================================================================
# OPTIONAL: Camera Configuration (Auto-detected by deployment script)
# =============================================================================
# Camera serial numbers (auto-detected, but can be manually set)
CAMERA_1_SERIAL=80000  # First camera serial number
CAMERA_2_SERIAL=88000  # Second camera serial number

# Dual camera mode (auto-detected, but can be manually set)
DUAL_CAMERA_MODE=true  # Enable dual camera mode
DUAL_CAMERA_MERGE_METHOD=side_by_side  # side_by_side or top_bottom

# =============================================================================
# OPTIONAL: Recording Configuration
# =============================================================================
# Video resolution (width x height)
RESOLUTION=1280x720

# Recording frame rate
RECORDING_FPS=30

# Video encoder (h264_v4l2m2m recommended for Pi)
VIDEO_ENCODER=h264_v4l2m2m

# =============================================================================
# OPTIONAL: System Configuration
# =============================================================================
# Timezone (defaults to system timezone)
LOCAL_TIMEZONE=UTC
SYSTEM_TIMEZONE=UTC

# Logging level
LOG_LEVEL=INFO

# Booking check interval (seconds)
BOOKING_CHECK_INTERVAL=3

# =============================================================================
# OPTIONAL: Service Configuration
# =============================================================================
# System status update interval (seconds)
SYSTEM_STATUS_INTERVAL=1

# Log upload interval (seconds)
LOG_UPLOAD_INTERVAL=900

# Log bucket name
LOG_BUCKET=logs

# =============================================================================
# OPTIONAL: Email Configuration (for share links)
# =============================================================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password_here
EMAIL_USE_TLS=True
EMAIL_FROM=your_email@gmail.com

# =============================================================================
# OPTIONAL: Share Link Configuration
# =============================================================================
SHARE_BASE_URL=https://api.ezrec.org

# =============================================================================
# OPTIONAL: File Paths (usually don't need to change)
# =============================================================================
RAW_RECORDINGS_DIR=/opt/ezrec-backend/recordings
PROCESSED_RECORDINGS_DIR=/opt/ezrec-backend/processed_recordings
MEDIA_CACHE_DIR=/opt/ezrec-backend/media_cache
LOGS_DIR=/opt/ezrec-backend/logs

# =============================================================================
# OPTIONAL: Log File Paths (usually don't need to change)
# =============================================================================
RECORDER_LOG=/opt/ezrec-backend/logs/recorder.log
VIDEO_WORKER_LOG=/opt/ezrec-backend/logs/video_worker.log
SYSTEM_STATUS_LOG=/opt/ezrec-backend/logs/system_status.log
LOG_COLLECTOR_LOG=/opt/ezrec-backend/logs/log_collector.log

# =============================================================================
# NOTES:
# =============================================================================
# 1. Camera serials are automatically detected during deployment
# 2. DUAL_CAMERA_MODE is automatically set based on camera detection
# 3. For dual camera setups, MERGE_METHOD can be:
#    - side_by_side (recommended)
#    - grid (vertical stack)
#    - picture_in_picture
# 4. All paths should be absolute paths
# 5. Make sure your user has video group permissions: sudo usermod -a -G video $USER 